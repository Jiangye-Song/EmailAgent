# ─── NextAuth.js v5 ───────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Local PostgreSQL (Docker) ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/email_agent

# ─── Qwen Cloud ───────────────────────────────────────────────────────────────
# Get your key at: https://home.qwencloud.com/api-keys
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ─── Alibaba Cloud OSS (Phase 2 — skip for local dev) ─────────────────────────
# ALIYUN_OSS_REGION=oss-ap-southeast-1
# ALIYUN_OSS_BUCKET=email-agent-assets
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=

# ─── Web Push Notifications ────────────────────────────────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:huckzishere@gmail.com

# ─── Cloudflare Email Routing ──────────────────────────────────────────────────
CF_INBOUND_SECRET=
INBOUND_DOMAIN=
